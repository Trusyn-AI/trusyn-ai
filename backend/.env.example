# Application
APP_NAME=Trusyn AI Backend
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
API_SUPPORTED_VERSIONS=v1
API_DEPRECATION_NOTICE=

# Database (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trusyn_ai
SQLALCHEMY_ECHO=false
SQLALCHEMY_POOL_PRE_PING=true
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=40
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=1800

# Security / JWT
SECRET_KEY=replace_with_strong_secret
REFRESH_SECRET_KEY=replace_with_strong_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_ISSUER=trusyn-ai

# Integrations (Gemini)
GEMINI_API_KEY=
GEMINI_TIMEOUT_SECONDS=15
GEMINI_RETRY_ATTEMPTS=2
GEMINI_RETRY_BACKOFF_SECONDS=0.5
GEMINI_CIRCUIT_FAIL_THRESHOLD=5
GEMINI_CIRCUIT_RECOVERY_SECONDS=60
GEMINI_RATE_LIMIT_PER_WINDOW=120

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Security headers
SECURITY_HEADERS_ENABLED=true
CSP_POLICY=default-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';
HSTS_MAX_AGE_SECONDS=31536000

# Request hardening
REQUEST_HARDENING_ENABLED=true
REQUEST_TIMEOUT_SECONDS=30
REQUEST_MAX_BODY_BYTES=1048576

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_PER_WINDOW=15
RATE_LIMIT_GATEWAY_PER_WINDOW=120
RATE_LIMIT_THREAT_INGEST_PER_WINDOW=120
RATE_LIMIT_WS_CONNECT_PER_WINDOW=60
RATE_LIMIT_DEFAULT_PER_WINDOW=300

# Redis / cache
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_DEFAULT_TTL_SECONDS=300
REDIS_CONNECT_TIMEOUT_SECONDS=2

# Observability / runtime
METRICS_ENABLED=true
METRICS_CACHE_TTL_SECONDS=15
TASK_SCHEDULER_ENABLED=true

# Real-time / Eventing / WebSocket
EVENT_BUS_QUEUE_SIZE=5000
EVENT_RETENTION_LIMIT=500
HEALTH_STREAM_INTERVAL_SECONDS=30
WS_HEARTBEAT_INTERVAL_SECONDS=20
WS_IDLE_TIMEOUT_SECONDS=120
WS_MAX_MESSAGE_SIZE=65536
WS_MAX_CONNECTIONS_GLOBAL=2000
WS_MAX_CONNECTIONS_PER_ORG=300
WS_MAX_SUBSCRIPTIONS_PER_CONNECTION=16
WS_BROADCAST_BATCH_SIZE=200

